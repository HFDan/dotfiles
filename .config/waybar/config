{
    "position": "top",
    "layer": "top",
    "output": ["eDP-1", "DP-3"],
    "height": 50,
    "fixed-center": true,
    "mode": "dock",
    "modules-left": ["tray", "wlr/workspaces", "mpris"],
    "modules-center": ["custom/dashboard"],
    "modules-right": ["custom/swww", "cava", "idle_inhibitor", "cpu", "memory", "pulseaudio", "battery", "clock", "custom/notiftray"],
    "wlr/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "sort-by-number": true,
        "all-outputs": true
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "アイドル状態ありません",
            "deactivated": "アイドル状態"
        }
    },
    "custom/dashboard": {
        "format": " 󰅀 ",
        "on-click": "~/.config/eww/open.sh",
        "tooltip": false
    },
    "mpris": {
        "format": "{player_icon} {title} - {artist}",
        "format-paused": "{status_icon} {title} - {artist}",
        "player-icons": {
            "default": "󰐊 ",
            "spotify": " "
        },
        "status-icons": {
            "paused": "  "
        },
        "ignored-players": [
            "firefox"
        ]
    },
    "cava": {
        "framerate": 60,
        "autosens": 1,
        "sensitivity": 100,
        "bars": 15,
        "lower_cutoff_freq": 50,
        "higher_cutoff_freq": 10000,
        "method": "pulse",
        "source": "auto",
        "stereo": true,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.20,
        "input_delay": 1,
        "format-icons" : ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█" ],
        "actions": {
           "on-click-right": "mode"
        }
    },
    "custom/swww": {
        "format": " 󰘻 ",
        "on-click": "~/.config/waybar/next_wall.sh",
        "tooltip": false
    },
    "custom/notiftray": {
        "format": "  ",
        "on-click": "/usr/bin/eww open notification --toggle",
        "tooltip": false
    },
    "tray": {
        "spacing": 10
    },
    "clock": {
        "format": "{:%I:%M %p %Y年%m月%d日}",
        "interval": 1,
        "max-length": 20
    },
    "pulseaudio": {
        "scroll-step": 1,
        "format": "ボリューム: {volume}%",
        "format-bluetooth": "ボリューム: {volume}% (BT)",
        "format-bluetooth-muted": "ボリューム: {icon} (BT)",
        "format-muted": "ボリューム: {volume}%",
        "on-click": "pavucontrol-qt"
    },
    "cpu": {
        "format": "CPU: {usage:3}%",
        "interval": 1
    },
    "memory": {
        "format": "RAM: {:3}%",
        "interval": 1
    },
    "custom/absclock": {
        "exec": "date +%s",
        "return-type": "{}",
        "format": "{}",
        "interval": 1
    },
    "custom/loadavg": {
        "exec": "cat /proc/loadavg | head -c 14",
        "return-type": "{}",
        "format": "Load average: {}",
        "interval": 1
    },
    "custom/uptime": {
        "exec": "uptime -p | sed 's/up //g' -",
        "return-type": "{}",
        "format": "Uptime: {}",
        "interval": 60,
    },
    "temperature": {
        "format": "Temperature: {temperatureC}°C",
        "interval": 1
    },
    "battery": {
        "format": "Battery: {capacity}%",
        "format-charging": "Battery: {capacity}% (charging)",
        "format-plugged": "Battery: {capacity}% (plugged)",
        "interval": 10
    },
    "network": {
        "format": "Network via {ifname}",
        "tooltip-format": "{ipaddr}/{cidr}",
        "format-linked": "Network (No IP) via {ifname}",
        "format-disconnected": "No network",
        "on-click": "nm-connection-editor"
    },
}
